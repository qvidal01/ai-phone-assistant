# AI Phone Assistant Configuration
# Copy this file to .env and fill in your values

# ===========================================
# AI BACKENDS
# ===========================================

# Anthropic Claude API (optional - can run with just Ollama)
ANTHROPIC_API_KEY=your_claude_api_key

# Ollama Configuration (local AI server)
OLLAMA_URL=http://192.168.0.234:11434
OLLAMA_DEFAULT_MODEL=quick-responder:latest
OLLAMA_SMART_MODEL=llama3.3:70b
OLLAMA_CHAT_MODEL=cyberque-chat:latest

# AI Routing
# Set to "true" to prefer local Ollama over Claude (saves API costs)
PREFER_LOCAL_AI=true
AI_TIMEOUT=30.0

# ===========================================
# TWILIO (Required)
# ===========================================
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ===========================================
# AI GATEWAY (Edge inference)
# ===========================================
AI_GATEWAY_URL=https://ai-gateway.aiqso.io
AI_GATEWAY_ENABLED=true
AI_GATEWAY_MODEL=auto

# ===========================================
# CRM INTEGRATION (Optional)
# ===========================================
# CRM_API_KEY=your_crm_api_key
# CRM_API_URL=https://api.yourcrm.com

# Odoo CRM
ODOO_URL=http://192.168.0.230:8069
ODOO_DATABASE=aiqso_db
ODOO_USERNAME=quinn@aiqso.io
ODOO_PASSWORD=your_odoo_password

# ===========================================
# CALENDAR/APPOINTMENTS (Optional)
# ===========================================
# EasyAppointments at cal.aiqso.io
EASYAPPOINTMENTS_URL=https://cal.aiqso.io
EASYAPPOINTMENTS_TOKEN=your_easyappointments_token

# Google Calendar (legacy)
# GOOGLE_CALENDAR_CREDENTIALS=/path/to/credentials.json
# CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ===========================================
# ESCALATION
# ===========================================
ESCALATION_PHONE=+12142335333

# ===========================================
# VOICE SETTINGS
# ===========================================
# Amazon Polly Neural voices (much more natural than default)
# Options: male_us, female_us, male_uk, female_uk, female_aus
TTS_VOICE=female_us

# ===========================================
# BUSINESS CONFIGURATION (Optional)
# ===========================================
# BUSINESS_NAME=Your Business Name
# BUSINESS_TYPE=auto_shop  # Options: auto_shop, salon, medical, general
# BUSINESS_HOURS=Mon-Fri 9am-5pm

# ===========================================
# APPLICATION SETTINGS
# ===========================================
DEBUG=false
LOG_LEVEL=INFO
